{
  "name": "@hahalololos/mcp-ssh",
  "version": "3.0.0",
  "description": "Final-target-first OpenSSH runtime for Model Context Protocol",
  "main": "server.mjs",
  "bin": {
    "mcp-ssh": "bin/mcp-ssh.js"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node bin/mcp-ssh.js",
    "dev": "node bin/mcp-ssh.js",
    "build": "echo \"Build skipped\"",
    "build:dxt": "bash scripts/build-dxt.sh",
    "test": "vitest run --coverage src/v3.test.mjs src/v3.contract.test.mjs",
    "test:unit": "vitest run src/v3.test.mjs src/v3.contract.test.mjs",
    "test:integration": "vitest run test-ssh/v3.integration.test.mjs",
    "test:contract": "vitest run src/v3.contract.test.mjs",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test",
    "version": "git add -A",
    "postversion": "git push && git push --tags"
  },
  "keywords": [
    "mcp",
    "ssh",
    "agent",
    "model-context-protocol",
    "claude",
    "ai",
    "remote",
    "server"
  ],
  "author": "aionda.com",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HaHas8468/mcp-ssh.git"
  },
  "homepage": "https://github.com/HaHas8468/mcp-ssh",
  "bugs": {
    "url": "https://github.com/HaHas8468/mcp-ssh/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "glob": "^11.0.3"
  },
  "optionalDependencies": {
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@anthropic-ai/dxt": "^0.2.5",
    "@types/node": "^20.11.26",
    "@types/ssh2": "^1.15.0",
    "@vitest/coverage-v8": "^4.1.4",
    "tmp": ">=0.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "tmp": ">=0.2.4",
    "vite": "^8.1.3"
  }
}
